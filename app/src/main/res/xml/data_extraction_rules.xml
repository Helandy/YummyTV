<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude
            domain="sharedpref"
            path="yani_auth_secure_preferences.xml" />
        <exclude
            domain="database"
            path="yummy_cache.db" />
        <exclude
            domain="database"
            path="yummy_cache.db-wal" />
        <exclude
            domain="database"
            path="yummy_cache.db-shm" />
        <exclude
            domain="database"
            path="yummy_cache.db-journal" />
    </cloud-backup>
    <device-transfer>
        <exclude
            domain="sharedpref"
            path="yani_auth_secure_preferences.xml" />
        <exclude
            domain="database"
            path="yummy_cache.db" />
        <exclude
            domain="database"
            path="yummy_cache.db-wal" />
        <exclude
            domain="database"
            path="yummy_cache.db-shm" />
        <exclude
            domain="database"
            path="yummy_cache.db-journal" />
    </device-transfer>
</data-extraction-rules>
